# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env in production
# Replace all placeholder values with real credentials

# Server Configuration
NODE_ENV=production
PORT=5000

# MongoDB Atlas (Cloud Database) - REQUIRED
# Get from: https://cloud.mongodb.com/
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/shriyash-foods?retryWrites=true&w=majority

# JWT Secret - CHANGE THIS! Use a strong random string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Razorpay LIVE Keys - REQUIRED for real payments
# Get from: https://dashboard.razorpay.com/app/keys
# IMPORTANT: Use LIVE keys (rzp_live_...) not test keys
RAZORPAY_KEY_ID=rzp_live_your_live_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret

# Shiprocket - REQUIRED for shipping
# Get from: https://app.shiprocket.in/seller/api
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_API_URL=https://apiv2.shiprocket.in/v1/external

# Frontend URL - Your deployed frontend URL
CLIENT_URL=https://your-domain.com

# Email Configuration - REQUIRED for order notifications
# For Gmail: Enable 2FA and create App Password
# Get from: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_business_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# SMS/OTP Service - REQUIRED for OTP verification
# Option 1: MSG91 (Popular in India)
# Get from: https://msg91.com/
SMS_API_KEY=your_msg91_api_key
SMS_SENDER_ID=SHRFOD

# Option 2: Twilio (Alternative)
# Get from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ========================================
# DEPLOYMENT CHECKLIST
# ========================================
# [ ] MongoDB Atlas cluster created and IP whitelisted
# [ ] Razorpay KYC completed and LIVE keys obtained
# [ ] Shiprocket account verified
# [ ] Gmail App Password generated
# [ ] SMS service (MSG91/Twilio) configured
# [ ] JWT_SECRET changed to strong random string
# [ ] CLIENT_URL updated to production domain
# [ ] All placeholder values replaced
# [ ] .env file added to .gitignore
# [ ] Environment variables set in hosting platform
